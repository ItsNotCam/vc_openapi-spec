{
	"name": "greg",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"dev": "bun run --filter @greg/server dev & bun run --filter @greg/nextjs dev",
