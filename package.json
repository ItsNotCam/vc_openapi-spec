		"@modelcontextprotocol/sdk": "^1.12.1",
		"axios": "1.14.0",
		"chromadb": "^1.9.2",
		"commander": "^13.1.0",
		"hono": "^4.7.7",
		"yaml": "^2.7.1",
		"zod": "^3.24.4"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.8.3"
	}
}
