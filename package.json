{
	"name": "openapi-chroma",
	"version": "0.1.0",
	"type": "module",
	"description": "OpenAPI spec ingestion into ChromaDB with MCP server for Claude",
	"main": "main.ts",
	"bin": {
		"openapi-chroma": "main.ts"
	},
	"scripts": {
		"start": "bun run main.ts serve",
		"dev": "bun run --watch main.ts serve",
